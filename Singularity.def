Bootstrap: docker
From: condaforge/miniforge3:latest

%files
    environment.yml /app/environment.yml
    . /app

%post
    # Install build tools
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        && rm -rf /var/lib/apt/lists/*

    # Build the environment from environment.yml into the base environment
    cd /app
    conda env update -n base -f environment.yml
    conda clean -afy

    # Install the application itself
    conda run -n base pip install --no-deps .

%environment
    export PATH=/opt/conda/bin:$PATH
    export LC_ALL=C
    export LANG=C

%runscript
    exec conda run --no-capture-output -n base pyseqrna "$@"

%labels
    Author Naveen Duhan
    Version 1.1.0
    Description pySeqRNA Singularity Container
